{
  "crons": [
    {
      "path": "/api/cron-send-followups",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron-awaiting-payment",
      "schedule": "0 * * * *"
    }
  ],
  "redirects": [
    { "source": "/admin.html",             "destination": "/bestsite",             "permanent": true },
    { "source": "/contact.html",           "destination": "/contact",           "permanent": true },
    { "source": "/faqs.html",              "destination": "/faqs",              "permanent": true },
    { "source": "/size-guide.html",        "destination": "/size-guide",        "permanent": true },
    { "source": "/shipping-delivery.html", "destination": "/shipping-delivery", "permanent": true },
    { "source": "/shipping-returns.html",  "destination": "/shipping-returns",  "permanent": true },
    { "source": "/track-order.html",       "destination": "/track-order",       "permanent": true },
    { "source": "/terms-of-service.html",  "destination": "/terms-of-service",  "permanent": true },
    { "source": "/privacy-policy.html",    "destination": "/privacy-policy",    "permanent": true },
    { "source": "/cookie-policy.html",     "destination": "/cookie-policy",     "permanent": true },
    { "source": "/catalog-admin.html",    "destination": "/catalog-admin",     "permanent": true },
    { "source": "/about.html",           "destination": "/about",             "permanent": true }
  ],
  "rewrites": [
    { "source": "/follow-up/:token",     "destination": "/follow-up.html" },
    { "source": "/bestsite",             "destination": "/admin.html" },
    { "source": "/about",               "destination": "/about.html" },
    { "source": "/catalog-admin",     "destination": "/catalog-admin.html" },
    { "source": "/contact",           "destination": "/contact.html" },
    { "source": "/faqs",              "destination": "/faqs.html" },
    { "source": "/size-guide",        "destination": "/size-guide.html" },
    { "source": "/shipping-delivery", "destination": "/shipping-delivery.html" },
    { "source": "/shipping-returns",  "destination": "/shipping-returns.html" },
    { "source": "/track-order",       "destination": "/track-order.html" },
    { "source": "/terms-of-service",  "destination": "/terms-of-service.html" },
    { "source": "/privacy-policy",    "destination": "/privacy-policy.html" },
    { "source": "/cookie-policy",     "destination": "/cookie-policy.html" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=(), payment=(self \"https://checkout.flutterwave.com\")" },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://www.gstatic.com https://cdn.jsdelivr.net https://checkout.flutterwave.com https://*.googletagmanager.com; style-src 'self' 'unsafe-inline' https://cdnjs.cloudflare.com; font-src 'self' https://cdnjs.cloudflare.com; img-src 'self' data: blob: https://firebasestorage.googleapis.com https://chunkz-store.firebasestorage.app https://*.google-analytics.com https://*.googletagmanager.com; connect-src 'self' https://ipapi.co https://ipinfo.io https://7107.api.greenapi.com https://formspree.io https://*.googleapis.com https://*.firebaseio.com wss://*.firebaseio.com https://checkout.flutterwave.com https://api.flutterwave.com https://*.google-analytics.com https://*.analytics.google.com https://*.googletagmanager.com; frame-src 'self' https://checkout.flutterwave.com https://chunkz-store.firebaseapp.com; object-src 'none'; base-uri 'self'; form-action 'self' https://formspree.io; upgrade-insecure-requests"
        }
      ]
    },
    {
      "source": "/(.*\\.(?:webp|jpg|jpeg|png|gif|ico|svg|woff2|woff|ttf|otf))",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
